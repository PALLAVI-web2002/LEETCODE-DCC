class Solution {
    
      public int fn(int min, int max){
        if(min == 0) {
            return max;
        }
        return fn(max%min, min);
    }
    public int findGCD(int[] nums) {
        int min = Integer.MAX_VALUE;
        int max = Integer.MIN_VALUE;
        int len = nums.length;
        for(int i = 0; i < len; i++){
            if (nums[i]<min){
                min = nums[i];
            }
            if(nums[i]>max){
                max = nums[i];
            }
        }
        int result = fn(min, max);
        return result;  
    }
}

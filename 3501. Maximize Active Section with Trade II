class Solution:
    def maxActiveSections(self, s: str, queries: List[List[int]]) -> List[int]:
        n = len(s)
        ones = s.count('1')
        
        # Precompute prefix sums for quick range queries
        pref = [0] * (n + 1)
        for i in range(n):
            pref[i + 1] = pref[i] + (1 if s[i] == '1' else 0)
        
        def count_ones(l, r):
            return pref[r + 1] - pref[l]
        
        ans = []
        
        for l, r in queries:
            length = r - l + 1
            total_ones = count_ones(l, r)
            
            # If all are ones or no valid trade possible
            if total_ones == length:
                ans.append(total_ones)
                continue
            
            # Check if there's at least one '1' surrounded by '0's
            # We need to find if there exists a '1' with '0' on both sides
            # within the augmented string: '1' + s[l:r+1] + '1'
            
            has_valid_trade = False
            
            # Check each '1' in the substring
            for i in range(l, r + 1):
                if s[i] == '1':
                    # Check if it has '0' on both sides within the augmented string
                    left_ok = (i > l and s[i-1] == '0') or (i == l)  # augmented '1' on left
                    right_ok = (i < r and s[i+1] == '0') or (i == r)  # augmented '1' on right
                    
                    # Actually, for a valid trade, the '1' must be surrounded by '0's
                    # In the augmented string, the edges are '1's, so a '1' at the edge
                    # of the substring is surrounded by '1' on one side and '0' on the other
                    # which doesn't count as "surrounded by '0's"
                    
                    # So the '1' must have '0' on BOTH sides
                    if i > l and i < r and s[i-1] == '0' and s[i+1] == '0':
                        has_valid_trade = True
                        break
            
            if not has_valid_trade:
                ans.append(total_ones)
                continue
            
            # With a valid trade, we can convert all zeros in the substring to ones
            ans.append(length)
        
        return ans
